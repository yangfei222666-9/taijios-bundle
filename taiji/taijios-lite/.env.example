# TaijiOS Lite 配置模板
# 复制本文件为 .env，填入你的 Key 即可
# 至少配一个 AI 模型的 Key，其余可选

# ── AI 模型 ───────────────────────────────────────
# DeepSeek（推荐，便宜好用）：https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-你的key

# Gemini（Google）：https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=AIza你的key

# Claude 官方（保底兜底）：https://console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-你的key

# Claude 中转站（可选，比官方便宜，与 ANTHROPIC_API_KEY 二选一）
# CLAUDE_RELAY_KEY=sk-你的中转key
# CLAUDE_RELAY_BASE=https://your-relay.com/v1

# ── 飞书 Bot（可选）──────────────────────────────
# FEISHU_APP_ID=cli_你的App_ID
# FEISHU_APP_SECRET=你的App_Secret

# ── Telegram Bot（可选）──────────────────────────
# TELEGRAM_BOT_TOKEN=你的Bot_Token

# ── API Server（可选）────────────────────────────
# Generate a strong token first: python tools/gen_token.py
# Placeholder values like "your-access-token" / "secret" / "test" are REJECTED
# at startup in non-loopback mode.
# TAIJIOS_API_TOKEN=<32+ char random hex>

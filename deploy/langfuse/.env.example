# TaijiOS Langfuse self-host · 拷成 .env 并填真值
# Generate secrets via:
#   python tools/gen_token.py --bytes 32   # for NEXTAUTH_SECRET & SALT
#   python tools/gen_token.py --bytes 32   # for ENCRYPTION_KEY (32 bytes = 64 hex)

POSTGRES_USER=langfuse
POSTGRES_PASSWORD=changeme_local_only
POSTGRES_DB=langfuse
POSTGRES_PORT=5433

LANGFUSE_PORT=3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=<run: python tools/gen_token.py --bytes 32>
SALT=<run: python tools/gen_token.py --bytes 16>
ENCRYPTION_KEY=<run: python tools/gen_token.py --bytes 32>
